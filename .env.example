# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/zimti

# 服务端口（默认 3000）
PORT=3000

# GLM 大模型（智谱AI）
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# Pexels 素材图库
PEXELS_API_KEY=your_pexels_api_key

# 即梦 AI（图片/视频生成）
JIMENG_AUTH_MODE=ark
JIMENG_BASE_URL=
JIMENG_API_KEY=
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=

# OpenAI（Whisper 语音转文字）
OPENAI_API_KEY=your_openai_api_key
